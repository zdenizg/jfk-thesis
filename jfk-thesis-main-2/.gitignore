*_checkpoint.json
*_progress.csv
*_interrupted.csv
*_error.csv

# OS files
.DS_Store
Thumbs.db

# R
.Rproj.user
.Rhistory
.RData
.Ruserdata
*.Rproj

# IDE
.vscode/
.idea/
EOF

# PDF
.PDF
*.pdf
*.PDF

ocr_output/

.db

# PDFs
*.pdf
*.PDF

# Databases
*.db

